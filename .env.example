# Required: your model provider API key
OPENAI_API_KEY=your_api_key_here

# Required for OpenAI-compatible providers
OPENAI_BASE_URL=https://your-provider.example.com/v1

# Required: token used on the Hermes Web UI login page
AUTH_TOKEN=change-this-to-a-long-random-string

# Optional: public web port inside the container
PORT=9119

# Optional: keep the internal Hermes gateway on loopback
UPSTREAM=http://127.0.0.1:8642

# Optional: persistent data and Hermes paths inside the container
DATA_DIR=/data
HERMES_HOME=/data/.hermes
HERMES_BIN=/opt/hermes/.venv/bin/hermes
